import random

def select_word(word_list):
    return random.choice(word_list)

def display_game_state(secret_word, guessed_letters, wrong_letters):
    display = []
    for ch in secret_word:
        if ch in guessed_letters:
            display.append(ch)
        else:
            display.append("_")

    print("\nKata:", " ".join(display))
    print("Salah:", ", ".join(wrong_letters) if wrong_letters else "-")
    print("Sisa nyawa:", 6 - len(wrong_letters))

def get_player_guess(guessed_letters, wrong_letters):
    while True:
        guess = input("Tebak huruf: ").lower().strip()

        if len(guess) != 1 or not guess.isalpha():
            print("1 doang dongg")
            continue

        if guess in guessed_letters or guess in wrong_letters:
            print("Lah nyoba itu lagi?")
            continue

        return guess

def play_hangman():
    words = ["python", "komputer", "program", "gaming", "fungsi"]
    secret_word = select_word(words)

    guessed_letters = set()
    wrong_letters = []

    while True:
        display_game_state(secret_word, guessed_letters, wrong_letters)

        if all(ch in guessed_letters for ch in secret_word):
            print("\nMENANGGG Kata-nya:", secret_word)
            break

        if len(wrong_letters) >= 6:
            print("\nGame over Kata nya yaitu:", secret_word)
            break

        guess = get_player_guess(guessed_letters, wrong_letters)

        if guess in secret_word:
            guessed_letters.add(guess)
            print("Nice!")
        else:
            wrong_letters.append(guess)
            print("Salah. Hurufnya nggak ada")

play_hangman()
